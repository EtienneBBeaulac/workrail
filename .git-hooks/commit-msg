#!/usr/bin/env bash
# commit-msg: validates conventional commit format.
#
# Runs automatically before every commit. If the message is invalid,
# it prints the full rules and exits 1 (blocking the commit).
#
# To install: run scripts/setup-hooks.sh

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")
FIRST_LINE=$(echo "$COMMIT_MSG" | head -1)

# ---------------------------------------------------------------------------
# Skip automated commits that have their own format
# ---------------------------------------------------------------------------

# Merge commits
if echo "$FIRST_LINE" | grep -qE "^Merge "; then exit 0; fi

# Revert commits generated by git revert
if echo "$FIRST_LINE" | grep -qE "^Revert \""; then exit 0; fi

# Fixup / squash commits (interactive rebase)
if echo "$FIRST_LINE" | grep -qE "^(fixup|squash)!"; then exit 0; fi

# ---------------------------------------------------------------------------
# Rules (printed on any violation so the author sees what to fix)
# ---------------------------------------------------------------------------

RULES=$(cat << 'RULES'
Commit message rules
====================

Format:  <type>(<scope>): <subject>
         <blank line>
         <optional body>

TYPES -- choose the one that best matches the change:

  feat      New user-visible feature.         -> minor version bump
  fix       Bug fix that affects users.       -> patch version bump
  perf      Performance improvement.          -> patch version bump
  revert    Reverts a previous commit.        -> patch version bump
  chore     Everything else: CI, deps, build, tooling, internal cleanup.
            Use chore -- not fix(ci), fix(deps), fix(build), etc.
  refactor  Code restructuring with no behavior change.
  docs      Documentation only.
  test      Adding or updating tests.

SCOPES -- use a product area, not an implementation label:

  Allowed:   console   mcp   workflows   engine   schema   docs
  Not allowed: phase2a  slice4  task123  sprint  ci  deps  build

SUBJECT LINE:

  - Write it for a user reading release notes, not a sprint tracker.
  - Bad:  "fix phase2a slice 4 dedup gap"       (internal jargon)
  - Bad:  "fix(ci): update validate:registry"   (use chore, not fix)
  - Good: "fix(console): restore scroll position on back-navigation"
  - Good: "feat(mcp): add examples field to list_workflows output"
  - Max 72 characters.
  - No period at the end.

RULES
)

# ---------------------------------------------------------------------------
# Validation
# ---------------------------------------------------------------------------

VALID_TYPES="feat|fix|chore|docs|refactor|test|perf|revert"
INTERNAL_SCOPES="phase|slice|task|sprint|ticket|ci|deps|build|wip"

# 1. Must match conventional commits format
if ! echo "$FIRST_LINE" | grep -qE "^($VALID_TYPES)(\([^)]+\))?: .+"; then
  echo ""
  echo "ERROR: commit message does not follow the conventional commits format."
  echo ""
  echo "$RULES"
  echo "Your first line: $FIRST_LINE"
  echo ""
  exit 1
fi

# 2. Scope must not be an internal tracking label
if echo "$FIRST_LINE" | grep -qiE "^($VALID_TYPES)\(($INTERNAL_SCOPES)[^)]*\):"; then
  echo ""
  echo "ERROR: scope looks like an internal tracking label, not a product area."
  echo ""
  echo "$RULES"
  echo "Your first line: $FIRST_LINE"
  echo ""
  exit 1
fi

# 3. Using fix(ci), fix(deps), fix(build) -- should be chore
if echo "$FIRST_LINE" | grep -qiE "^fix\((ci|deps|build|lint|test|tooling)[^)]*\):"; then
  echo ""
  echo "ERROR: use 'chore' for CI/deps/build changes, not 'fix'."
  echo "  fix(ci): ...   ->   chore: ..."
  echo "  fix(deps): ... ->   chore(deps): ..."
  echo ""
  echo "$RULES"
  echo "Your first line: $FIRST_LINE"
  echo ""
  exit 1
fi

# 4. Subject line length
if [ "${#FIRST_LINE}" -gt 72 ]; then
  echo ""
  echo "ERROR: first line is ${#FIRST_LINE} characters (max 72)."
  echo ""
  echo "$RULES"
  echo "Your first line: $FIRST_LINE"
  echo ""
  exit 1
fi

exit 0
