+      return { width: CHECKPOINT_SIZE, height: CHECKPOINT_SIZE };
+    case 'blocked_attempt':
+      return { width: BLOCKED_NODE_WIDTH, height: NODE_HEIGHT };
+    case 'step':
+      return { width: STEP_NODE_WIDTH, height: NODE_HEIGHT };
+  }
